# Cube.js API secret — must match CUBEJS_API_SECRET used by the Go backend to sign JWTs
CUBEJS_API_SECRET=your-secret-here

# PostgreSQL connection (point to the same DB as services/main)
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=localhost
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=your_database
CUBEJS_DB_USER=your_user
CUBEJS_DB_PASS=your_password
CUBEJS_DB_SSL=false

# Server port (Cube default is 4000)
PORT=4000

# Development mode: 'true' enables the Cube Playground UI
CUBEJS_DEV_MODE=true
